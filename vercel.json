{
  "version": 2,
  "functions": {
    "api/index.ts": {
      "memory": 1024,
      "maxDuration": 10
    }
  },
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/index.ts"
    },
    {
      "source": "/articles/:slug",
      "destination": "/api/bot-render.ts"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
